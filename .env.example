APP_ENV=development
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_MODE=local
OIDC_ISSUER_URL=
OIDC_JWKS_URL=
OIDC_AUDIENCE=
OIDC_ROLE_CLAIM=role
OIDC_ASSET_GROUPS_CLAIM=asset_group_ids
# US cloud: https://cloud.appscan.com
# EU cloud: https://eu.cloud.appscan.com
# Effective API base: <ASOC_SERVICE_URL>/api/v4/...
# Primary endpoint (single-endpoint and backward-compatible mode)
ASOC_SERVICE_URL=https://cloud.appscan.com
ASOC_API_KEY=
ASOC_API_SECRET=
# Multi-endpoint JSON (set by installer when multiple ASoC endpoints are configured).
# Format: [{"url":"https://...","key":"...","secret":"...","label":"..."},...]
# When set, takes precedence over the primary ASOC_SERVICE_URL/KEY/SECRET fields
# for multi-endpoint operations.  Leave blank for single-endpoint deployments.
ASOC_ENDPOINTS_JSON=
ASOC_READ_ONLY=true
# Pagination tuning — override defaults only if needed.
# ASOC_PAGE_SIZE controls items per API page (max 1000; higher = fewer requests).
# ASOC_MAX_PAGES caps total pages fetched for scans/apps (safety limit).
# ASOC_ISSUE_MAX_PAGES_PER_APP caps issue pages per application.
# ASOC_COUNT_TIMEOUT_SECONDS sets the HTTP timeout for /Count endpoint calls.
# ASOC_USE_COUNT_ENDPOINTS enables the fast /Count strategy for accurate KPI totals.
ASOC_PAGE_SIZE=1000
ASOC_MAX_PAGES=500
ASOC_ISSUE_MAX_PAGES_PER_APP=1000
ASOC_COUNT_TIMEOUT_SECONDS=30
ASOC_USE_COUNT_ENDPOINTS=true
REPORT_SCHEDULER_ENABLED=true
REPORT_SCHEDULER_INTERVAL_SECONDS=30
REPORT_SCHEDULER_MAX_RETRIES=5
ANALYTICS_CACHE_TTL_SECONDS=3600
ANALYTICS_CACHE_CLEANUP_INTERVAL_SECONDS=600
ANALYTICS_SCAN_SEVERITY_SOURCE=hybrid
ANALYTICS_PREWARM_ENABLED=true
ANALYTICS_PREWARM_INTERVAL_SECONDS=1800
REPORT_SCHEDULER_BACKOFF_BASE_SECONDS=60
REPORT_SCHEDULER_BACKOFF_MAX_SECONDS=3600
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:55432/aspm
REDIS_URL=redis://localhost:6379/0
VITE_SCOPE_FILTERS_ENABLED=true
